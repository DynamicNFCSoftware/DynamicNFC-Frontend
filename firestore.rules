rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper: check if user is admin
    function isAdmin() {
      return request.auth != null
        && exists(/databases/$(database)/documents/admins/$(request.auth.token.email));
    }

    // User-created digital cards — public read, owner write
    match /cards/{cardId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null
        && resource.data.userId == request.auth.uid;
    }

    // NFC smart cards — public read, admin-only write
    match /smartcards/{cardId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Tap logs — public create with validation, admin-only read
    match /taps/{tapId} {
      allow read: if isAdmin();
      allow create: if true;
      allow update, delete: if false;
    }

    // Campaigns — admin only
    match /campaigns/{campaignId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Admin roster — admin read, console-only write
    match /admins/{email} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Behavioral events — public create with validation, admin-only read
    match /behaviors/{behaviorId} {
      allow create: if true;
      allow read: if isAdmin();
      allow update, delete: if false;
    }

    // Settings — admin only write, authenticated read
    // Includes:
    //   - settings/cleanup-exempt: { uids: [...], emails: [...], reason: {...} }
    //     → used by inactivity cleanup Cloud Function to skip protected accounts.
    match /settings/{settingId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Wallet pass requests — authenticated users
    match /walletPassRequests/{docId} {
      allow create: if request.auth != null;
      allow read: if request.auth != null;
      allow update, delete: if false;
    }

    // Wallet passes — read only
    match /walletPasses/{cardId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    // Testimonials — public read, admin write
    match /testimonials/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Blog posts — public read, admin write
    match /blog_posts/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Newsletter subscribers — public create, admin read
    match /newsletter_subscribers/{docId} {
      allow create: if true
        && request.resource.data.email is string
        && request.resource.data.email.size() <= 100;
      allow read: if request.auth != null;
      allow update, delete: if isAdmin();
    }

    // Tenant isolation for /unified workspace
    // Owner-only read/write on tenants/{uid} and ALL subcollections.
    //
    // Reserved root-doc fields (managed by app + cleanup function):
    //   - lastActivity:      Timestamp  → updated on login, heartbeat (12h), meaningful writes
    //   - seedVersion:       number     → idempotent demo seed marker (first-login seed)
    //   - seedComplete:      boolean    → true once initial seed finished
    //   - schemaVersion:     number     → schema version for migrations
    //   - cleanupEligible:   boolean    → false = permanent exempt (rare; prefer settings/cleanup-exempt)
    //   - pendingDeletionAt: Timestamp  → soft-delete marker set by cleanup function
    //                                     (auto-cleared by updateLastActivity on any write;
    //                                      hard delete happens 7 days after this is set)
    //
    // NOTE: Cloud Functions (cleanup) use Admin SDK and bypass these rules.
    match /tenants/{userId} {
      allow read, write: if request.auth != null
        && request.auth.uid == userId;

      match /{subcollection}/{document} {
        allow read: if request.auth != null
          && request.auth.uid == userId;
        allow delete: if request.auth != null
          && request.auth.uid == userId;
        // Allow create/update but block client from modifying server-managed 'aggregates' field
        allow create, update: if request.auth != null
          && request.auth.uid == userId
          && (!('aggregates' in request.resource.data)
              || (resource != null && request.resource.data.aggregates == resource.data.aggregates));
      }
    }
  }
}
